# Host profile: standard
# Maxed-out Raspberry Pi 5 class host: 4 cores, 16GB RAM, SSD/NVMe storage,
# sized to support ~5000 miners. Selected via FLEET_PROFILE in the
# deployment .env; override any single key by setting it in .env (operator
# values win).

# Connection slots; covers the app pool plus ~20 reserved sessions without wasting memory
PG_MAX_CONNECTIONS=200
# Postgres page cache; 25% of 16GB, the ceiling when the DB shares the host with fleet-api
PG_SHARED_BUFFERS=4GB
# Planner's estimate of pages cached by postgres + OS; ~half of RAM
PG_EFFECTIVE_CACHE_SIZE=8GB
# Per-sort/hash memory; 16MB keeps the worst case (pool x work_mem x parallel
# helpers) inside the RAM left after shared_buffers on a shared 16GB host
PG_WORK_MEM=16MB
# Vacuum/index maintenance memory; hypertables at 5000-device scale are large
PG_MAINTENANCE_WORK_MEM=256MB
# WAL staging buffer; absorbs 5000-device ingest bursts between flushes
PG_WAL_BUFFERS=32MB
# Fewer checkpoints smooth ingest I/O; SSD makes the longer recovery replay acceptable
PG_CHECKPOINT_TIMEOUT=15min
# Compress full-page WAL images; heavy ingest generates them constantly, CPU cost is small
PG_WAL_COMPRESSION=lz4
# Parallel-query worker pool; all 4 cores may serve wide fleet chart queries
PG_MAX_PARALLEL_WORKERS=4
# Helpers per query; two keeps a single chart from taking every core
PG_MAX_PARALLEL_WORKERS_PER_GATHER=2
# Vacuum/index-build helpers; same two-core budget per operation
PG_MAX_PARALLEL_MAINTENANCE_WORKERS=2
# Timescale job slots; compression + hourly/daily rollups need more headroom at 5000 devices
PG_TS_MAX_BACKGROUND_WORKERS=6
# Total worker slots: 6 background + 4 parallel + 3 extras (identity enforced by tests)
PG_MAX_WORKER_PROCESSES=13
# Allow large aggregation spills but cap a runaway query's disk use
PG_TEMP_FILE_LIMIT=2GB
# /dev/shm for parallel-query shared memory over 5000-device aggregations
PG_SHM_SIZE=512mb
# fleet-api pool; sized for concurrent ingest + dashboards, under max_connections with reserve
DB_MAX_OPEN_CONNS=100
# Idle connections kept warm to serve the steady ingest write load
DB_MAX_IDLE_CONNS=25
# Device poll cadence; 5000 devices at 10s is ~500 polls/s, sustainable on 4 cores
TELEMETRY_FETCH_INTERVAL=10s
# When a device counts as stale; 3x the fetch interval so one missed poll is not "stale"
TELEMETRY_STALENESS_THRESHOLD=30s
# Concurrent device polls; 250 in flight drains a 5000-device sweep well inside the 10s cadence
TELEMETRY_CONCURRENCY_LIMIT=250
# Per-device poll timeout; slack for congested miner networks without stalling the sweep
TELEMETRY_METRIC_TIMEOUT=8s
# Dashboard query budget; wide-fleet charts on 4 cores can legitimately take over a minute
TIMESCALEDB_QUERY_TIMEOUT=90s
# Row cap per chart query; bounds response size and fleet-api memory at 5000 devices
TIMESCALEDB_MAX_TIME_SERIES_ROWS=50000
# Skip the WAL flush per telemetry batch; per-batch flushes throttle 5000-device ingest
TIMESCALEDB_ASYNC_METRIC_COMMIT=true
# Concurrent command executions; mass ops on 5000 miners without swamping the poller cores
FLEET_COMMAND_MAX_WORKERS=250
