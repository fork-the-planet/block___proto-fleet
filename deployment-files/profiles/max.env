# Host profile: max
# Dedicated server: 8+ cores, 32GB+ RAM, NVMe storage, 5000+ miners.
# Aggressive on performance AND durability: telemetry commits stay
# synchronous and checkpoint_timeout stays moderate to bound crash-recovery
# time. Selected via FLEET_PROFILE in the deployment .env; override any
# single key by setting it in .env (operator values win).

# Postgres page cache; 25% of 32GB, the ceiling when the DB shares the host
PG_SHARED_BUFFERS=8GB
# Planner's estimate of pages cached by postgres + OS; most of RAM holds the working set
PG_EFFECTIVE_CACHE_SIZE=24GB
# Per-sort/hash memory; big fleet aggregations sort in memory instead of spilling
PG_WORK_MEM=64MB
# Vacuum/index maintenance memory; fast rebuilds on large hypertables
PG_MAINTENANCE_WORK_MEM=1GB
# WAL staging buffer; absorbs ingest bursts from 5000+ devices
PG_WAL_BUFFERS=64MB
# Floor of recycled WAL kept on disk; avoids file churn under steady heavy ingest
PG_MIN_WAL_SIZE=2GB
# WAL ceiling that forces a checkpoint; room for write bursts between checkpoints
PG_MAX_WAL_SIZE=8GB
# The durability half of this profile: shorter than the Pi profiles to bound crash-recovery replay
PG_CHECKPOINT_TIMEOUT=10min
# Compress full-page WAL images; less write amplification and CPU is plentiful
PG_WAL_COMPRESSION=lz4
# Read-ahead depth; NVMe serves deep I/O queues
PG_EFFECTIVE_IO_CONCURRENCY=256
# Timescale job slots; headroom for every compression/rollup/retention job at scale
PG_TS_MAX_BACKGROUND_WORKERS=12
# Total worker slots: 12 background + 8 parallel + 3 extras (identity enforced by tests)
PG_MAX_WORKER_PROCESSES=23
# Generous spill allowance for ad-hoc analytics, still capped against runaway queries
PG_TEMP_FILE_LIMIT=8GB
# Tighter slow-query bar; on this hardware anything over 500ms deserves a look
PG_LOG_MIN_DURATION_STATEMENT=500
# /dev/shm for parallel-query shared memory; 8-way parallel aggregations need room
PG_SHM_SIZE=2gb
# fleet-api pool; scales concurrent dashboards + ingest, under the 300-connection default with reserve
DB_MAX_OPEN_CONNS=150
# Concurrent device polls; drains a 5000+ device sweep in seconds with cores to spare
TELEMETRY_CONCURRENCY_LIMIT=1000
# Concurrent command executions; mass ops across the whole fleet finish quickly
FLEET_COMMAND_MAX_WORKERS=1000
