# Host profile: mini
# Low-power host (Raspberry Pi class), <=4GB RAM, SD/USB storage, up to
# ~200 miners. Selected via FLEET_PROFILE in the deployment .env; override
# any single key by setting it in .env (operator values win).

# Connection slots; each costs server memory, so keep the ceiling low on 4GB
PG_MAX_CONNECTIONS=100
# Postgres page cache; ~12% of 4GB leaves room for fleet-api and the OS cache
PG_SHARED_BUFFERS=512MB
# Planner's estimate of pages cached by postgres + OS; ~40% of 4GB
PG_EFFECTIVE_CACHE_SIZE=1536MB
# Per-sort/hash memory; keeps the worst case (connections x work_mem) bounded
PG_WORK_MEM=8MB
# Floor of recycled WAL kept on disk; small to save SD space
PG_MIN_WAL_SIZE=256MB
# WAL ceiling that forces a checkpoint; bounds disk use and crash recovery on SD
PG_MAX_WAL_SIZE=1GB
# Fewer checkpoints mean fewer full-page writes, reducing SD-card wear
PG_CHECKPOINT_TIMEOUT=15min
# Compress full-page WAL images; cuts write volume on slow storage for little CPU
PG_WAL_COMPRESSION=lz4
# Tell the planner random reads are expensive on SD cards, favoring sequential plans
PG_RANDOM_PAGE_COST=2.0
# Read-ahead depth; SD cards cannot serve deep I/O queues
PG_EFFECTIVE_IO_CONCURRENCY=4
# Parallel-query worker pool; leave 2 of the 4 cores for fleet-api and the poller
PG_MAX_PARALLEL_WORKERS=2
# Helpers per query; at most one extra core per chart query
PG_MAX_PARALLEL_WORKERS_PER_GATHER=1
# Vacuum/index-build helpers; same one-extra-core budget
PG_MAX_PARALLEL_MAINTENANCE_WORKERS=1
# Timescale job slots; enough for staggered compression/rollup at ~200 devices
PG_TS_MAX_BACKGROUND_WORKERS=4
# Total worker slots: 4 background + 2 parallel + 3 extras (identity enforced by tests)
PG_MAX_WORKER_PROCESSES=9
# Cap per-query spill files so one bad query cannot fill the SD card
PG_TEMP_FILE_LIMIT=512MB
# Per-I/O clock reads are comparatively expensive on low-power ARM
PG_TRACK_IO_TIMING=off
# Log queries over 2s; everything is slower here, so keep the log signal high
PG_LOG_MIN_DURATION_STATEMENT=2000
# /dev/shm for parallel-query shared memory; minimal parallelism needs little
PG_SHM_SIZE=128mb
# fleet-api pool; stays under max_connections with ~20 slots reserved for grafana/psql
DB_MAX_OPEN_CONNS=40
# Idle connections kept warm; low to release memory between bursts
DB_MAX_IDLE_CONNS=10
# Device poll cadence; half the default rate halves steady-state load
TELEMETRY_FETCH_INTERVAL=10s
# When a device counts as stale; 3x the fetch interval so one missed poll is not "stale"
TELEMETRY_STALENESS_THRESHOLD=30s
# Concurrent device polls; bounds sockets and goroutines on a 4GB host
TELEMETRY_CONCURRENCY_LIMIT=100
# Per-device poll timeout; congested Pi networks need extra slack
TELEMETRY_METRIC_TIMEOUT=8s
# Dashboard query budget; aborting a chart this hardware needs 70s to build means it never loads
TIMESCALEDB_QUERY_TIMEOUT=90s
# Row cap per chart query; bounds fleet-api response memory
TIMESCALEDB_MAX_TIME_SERIES_ROWS=25000
# Skip the WAL flush per telemetry batch; SD flushes are slow and a sub-second loss window is acceptable
TIMESCALEDB_ASYNC_METRIC_COMMIT=true
# Concurrent command executions; sized with the poller so both fit the cores
FLEET_COMMAND_MAX_WORKERS=100
