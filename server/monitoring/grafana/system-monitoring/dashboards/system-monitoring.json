    {
      "type": "table",
      "title": "Slowest queries by mean time",
      "description": "From pg_stat_statements (cumulative since last stats reset). Utility statements are excluded (pg_stat_statements.track_utility=off).",
      "datasource": { "type": "postgres", "uid": "protofleet-timescaledb" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "query" },
            "properties": [{ "id": "custom.width", "value": 600 }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT left(query, 200) AS query, calls, round(mean_exec_time::numeric, 2) AS mean_ms, round(max_exec_time::numeric, 2) AS max_ms, rows AS total_rows FROM fleet_slow_statements() ORDER BY mean_exec_time DESC LIMIT 20"
        }
      ]
    },
    {
      "type": "table",
      "title": "Costliest queries by total time",
      "description": "Where the database actually spends its time: high-frequency queries surface here even when each call is fast.",
      "datasource": { "type": "postgres", "uid": "protofleet-timescaledb" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "query" },
            "properties": [{ "id": "custom.width", "value": 600 }]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT left(query, 200) AS query, calls, round(total_exec_time::numeric, 2) AS total_ms, round(mean_exec_time::numeric, 2) AS mean_ms FROM fleet_slow_statements() ORDER BY total_exec_time DESC LIMIT 20"
        }
      ]
    }
  ],
