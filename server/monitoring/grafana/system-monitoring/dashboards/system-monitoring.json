  "panels": [
    {
      "type": "timeseries",
      "title": "Host CPU used %",
      "datasource": { "type": "postgres", "uid": "protofleet-timescaledb" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT time, value AS \"CPU used %\" FROM notification_metric_sample WHERE metric = 'fleet_system_cpu_used_percent' AND $__timeFilter(time) ORDER BY time"
        }
      ]
    },
